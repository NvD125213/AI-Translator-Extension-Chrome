{
  "manifest_version": 3,
  "name": "AI Translator",
  "version": "1.0",
  "description": "Dịch trang web và đoạn text bằng AI. Bôi đen chữ rồi nhấn chuột phải và chọn sử dụng extension để dịch. Lưu API key an toàn, theo dõi token và chi phí.",

  "permissions": ["activeTab", "storage", "scripting", "tabs", "contextMenus"],

  "host_permissions": ["<all_urls>"],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
